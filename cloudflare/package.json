{
  "name": "moon-auth-service",
  "version": "1.0.0",
  "description": "Moon Private Auth Service - Cloudflare Workers",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "esbuild src/index.ts --bundle --platform=worker --outfile=dist/index.js --format=esm",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 execute moon-auth --local --file=./d1/migrations/0001_initial_schema.sql",
    "db:migrate:prod": "wrangler d1 execute moon-auth --remote --file=./d1/migrations/0001_initial_schema.sql",
    "db:seed:local": "wrangler d1 execute moon-auth --local --file=./d1/seed.sql",
    "db:seed:prod": "wrangler d1 execute moon-auth --remote --file=./d1/seed.sql",
    "admin:license": "node scripts/admin.mjs add-license",
    "admin:upload": "node scripts/admin.mjs upload-release",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "hono-rate-limiter": "^0.4.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@cloudflare/workers-types": "^4.20240620.0",
    "dotenv": "^16.4.5",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.0",
    "wrangler": "^3.60.0"
  },
  "engines": {
    "node": ">=18"
  }
}
